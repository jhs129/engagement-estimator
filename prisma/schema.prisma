generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CLIENT_ADMIN
  USER
}

// NextAuth adapter tables
model User {
  id            String    @id @default(cuid())
  name          String?
  firstName     String?
  lastName      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  apiTokens          ApiToken[]
  oauthAuthCodes     OAuthAuthCode[]
  oauthRefreshTokens OAuthRefreshToken[]
  oauthConsents      OAuthConsent[]
  estimates          Estimate[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  tokenHash  String    @unique
  prefix     String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// OAuth 2.1 authorization server tables
model OAuthClient {
  id                String              @id @default(cuid())
  clientId          String              @unique
  clientName        String
  redirectUris      String[]
  clientSecretHash  String?
  createdAt         DateTime            @default(now())
  authCodes         OAuthAuthCode[]
  refreshTokens     OAuthRefreshToken[]
  consents          OAuthConsent[]
}

model OAuthAuthCode {
  id                  String       @id @default(cuid())
  code                String       @unique
  clientId            String
  userId              String
  redirectUri         String
  codeChallenge       String
  codeChallengeMethod String
  scope               String
  expiresAt           DateTime
  consumedAt          DateTime?
  createdAt           DateTime     @default(now())
  client              OAuthClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthRefreshToken {
  id          String       @id @default(cuid())
  tokenHash   String       @unique
  clientId    String
  userId      String
  scope       String
  expiresAt   DateTime
  revokedAt   DateTime?
  replacedBy  String?
  createdAt   DateTime     @default(now())
  client      OAuthClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthConsent {
  id        String       @id @default(cuid())
  userId    String
  clientId  String
  scope     String
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    OAuthClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
}

// Engagement Estimator models

model Client {
  id        String     @id @default(cuid())
  name      String
  logoUrl   String     @default("")
  createdAt DateTime   @default(now())
  projects  Project[]
  estimates Estimate[]
}

model Project {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String     @default("")
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  estimates   Estimate[]
}

model Estimate {
  id                     String   @id @default(cuid())
  name                   String
  clientName             String
  salesOwner             String
  salesOriginator        String?
  clientId               String?
  client                 Client?  @relation(fields: [clientId], references: [id])
  projectId              String?
  project                Project? @relation(fields: [projectId], references: [id])
  estimatedStartDate     DateTime?
  projectDescription     String?
  version                Float    @default(4.0)
  riskPremiumPct         Float    @default(0.15)

  smeTechnology          String?
  smeCreativeUX          String?
  smeStrategy            String?
  smeData                String?
  smeMedia               String?
  smeMarketingAutomation String?
  smeOther               String?

  ratioQAToDev           Float @default(0.20)
  ratioTestCaseAuthoring Float @default(0.10)
  ratioDefectFixing      Float @default(0.25)
  ratioAlphaTesting      Float @default(0.20)
  ratioUAT               Float @default(0.10)

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions   Question[]
  teamMembers TeamMember[]
  epics       Epic[]
  stories     Story[]
  smes        EstimateSme[]
}

model EstimateSme {
  id         String   @id @default(cuid())
  estimateId String
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  name       String
  domain     String?
  order      Int

  @@index([estimateId])
}

model LaborRole {
  id           String  @id @default(cuid())
  fullTitle    String
  division     String
  department   String
  role         String
  rackRate     Float
  abbreviation String
  isActive     Boolean @default(true)

  teamMembers TeamMember[]
}

model TeamMember {
  id                   String     @id @default(cuid())
  estimateId           String
  estimate             Estimate   @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  laborRoleId          String?
  laborRole            LaborRole? @relation(fields: [laborRoleId], references: [id])
  titleOverride        String?
  abbreviationOverride String?
  rackRateOverride     Float?
  adjustedClientRate   Float?
  targetedResource     String?
  order                Int

  storyStaffing StoryStaffing[]
  staffingWeeks StaffingWeek[]
}

model Question {
  id          String   @id @default(cuid())
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  type        String
  description String
  notes       String?
  order       Int
}

model Epic {
  id           String   @id @default(cuid())
  estimateId   String
  estimate     Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  isFoundation Boolean  @default(false)
  order        Int

  stories Story[]
}

model Story {
  id            String   @id @default(cuid())
  estimateId    String
  estimate      Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  epicId        String
  epic          Epic     @relation(fields: [epicId], references: [id])
  storyTask     String
  description   String?
  assumptions   String?
  deliverables  String?
  disabled      Boolean  @default(false)
  testable      Boolean  @default(false)
  estimateLow   Float?
  estimateHigh  Float?
  estimateMean  Float?
  order         Int

  staffingAllocations StoryStaffing[]
}

model StoryStaffing {
  id           String     @id @default(cuid())
  storyId      String
  story        Story      @relation(fields: [storyId], references: [id], onDelete: Cascade)
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  hours        Float      @default(0)

  @@unique([storyId, teamMemberId])
}

model StaffingWeek {
  id            String     @id @default(cuid())
  teamMemberId  String
  teamMember    TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  weekStartDate DateTime
  hours         Float      @default(0)

  @@unique([teamMemberId, weekStartDate])
}
