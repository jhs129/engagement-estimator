# Database (Neon PostgreSQL)
DATABASE_URL=

# NextAuth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=https://your-app.vercel.app

# Google OAuth (console.cloud.google.com)
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID (portal.azure.com → App registrations)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=

# Admin access — this email gets ADMIN role automatically
ADMIN_EMAIL=

# MCP OAuth 2.1 RSA keys (RS256)
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste PEM contents below, replacing literal newlines with \n
OAUTH_PRIVATE_KEY=
OAUTH_PUBLIC_KEY=
# Arbitrary string identifier for the key, e.g. "eng-est-key-1"
OAUTH_KID=
